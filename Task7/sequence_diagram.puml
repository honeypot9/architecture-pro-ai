@startuml RAG_System_Evaluation_Sequence_Diagram

title Sequence Diagram: RAG System Evaluation Process

actor User
participant "Test Evaluator" as Evaluator
participant "Enhanced RAG Engine" as RAGEngine
participant "FAISS Searcher" as FAISS
participant "YandexGPT" as LLM
participant "Query Logger" as Logger
participant "Report Generator" as Report

User -> Evaluator: Start Evaluation
activate Evaluator

Evaluator -> Evaluator: Load Golden Questions
Evaluator -> Evaluator: Initialize RAG Engine & Logger

loop For Each Question
    Evaluator -> RAGEngine: Submit Question
    activate RAGEngine

    RAGEngine -> FAISS: Search Similar Documents
    activate FAISS
    FAISS -> FAISS: Vector Similarity Search
    FAISS --> RAGEngine: Return Relevant Chunks
    deactivate FAISS

    alt Found Relevant Chunks
        RAGEngine -> LLM: Generate Answer with Context
        activate LLM
        LLM --> RAGEngine: Return Generated Answer
        deactivate LLM
        RAGEngine -> RAGEngine: Prepare Response Data
    else No Relevant Chunks Found
        RAGEngine -> RAGEngine: Prepare "No Information" Response
    end

    RAGEngine -> Logger: Log Query & Response
    activate Logger
    Logger --> RAGEngine: Logging Complete
    deactivate Logger

    RAGEngine --> Evaluator: Return Response Data
    deactivate RAGEngine

    Evaluator -> Evaluator: Evaluate Response Quality
    Evaluator -> Evaluator: Store Test Result
end

Evaluator -> Report: Generate Evaluation Report
activate Report
Report --> Evaluator: Report Generated
deactivate Report

Evaluator -> User: Display Results & Accuracy
deactivate Evaluator

@enduml
